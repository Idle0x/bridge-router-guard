# ─────────────────────────────────────────────────────────────────────────────
# .env.template
#
# Copy to .env and fill in values as deployments complete.
# NEVER commit .env to version control. Add to .gitignore immediately.
#
# Workflow:
#   1. Set PRIVATE_KEY before any deployment
#   2. Run DeployMocks.s.sol → fill TOKEN_ADDR through ROUTER_ADDR
#   3. Run DeployResponse.s.sol → fill RESPONSE_CONTRACT
#   4. Run `drosera apply` → fill DROSERA_EXECUTOR and EXPECTED_TRAP
#   5. Generate ALERT_SECRET → openssl rand -hex 32
#   6. Set SLACK_WEBHOOK_URL from your Slack app configuration
# ─────────────────────────────────────────────────────────────────────────────
PRIVATE_KEY=0x<your_private_key_here>

# Filled after DeployMocks.s.sol
TOKEN_ADDR=
ORACLE_ADDR=
VALIDATOR_ADDR=
VAULT_ADDR=
GATEWAY_ADDR=
ROUTER_ADDR=

# Filled after DeployResponse.s.sol
RESPONSE_CONTRACT=

# Filled after `drosera apply`
DROSERA_EXECUTOR=
EXPECTED_TRAP=

# Alert server authentication (generate: openssl rand -hex 32)
ALERT_SECRET=

# Slack incoming webhook URL (never commit)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
